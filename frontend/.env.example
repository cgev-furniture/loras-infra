# LORAS Furniture — Frontend environment variables (Vite)
# Copy this file to .env and fill in values before running locally.
# NEVER commit the actual .env file to version control.
#
# IMPORTANT: All VITE_* variables are embedded into the JavaScript bundle at
# BUILD TIME by Vite.  They are not available at runtime.  In production these
# values are passed as --build-arg arguments to the Docker build step in
# cloudbuild.yaml.

# -----------------------------------------------------------------------
# Backend API base URL — no trailing slash
# Local: point to the Docker Compose backend container port
# Production: set to the Cloud Run backend service URL in cloudbuild.yaml
# -----------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------
# Contact / social channels
# These are embedded at build time to avoid a runtime API call for simple
# static values.
# -----------------------------------------------------------------------
VITE_WHATSAPP_NUMBER=37498110895
VITE_CONTACT_EMAIL=asryantigran@gmail.com
VITE_INSTAGRAM_HANDLE=lorasfurniture
