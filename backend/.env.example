# LORAS Furniture — Backend environment variables
# Copy this file to .env and fill in all values before running locally.
# NEVER commit the actual .env file to version control.
#
# Production note: DB_PASSWORD, JWT_SECRET, and MAIL_PASSWORD are sourced from
# GCP Secret Manager via --set-secrets in the Cloud Run deploy step — do NOT
# set them as plain env vars in production.

# -----------------------------------------------------------------------
# Database (Cloud SQL via Cloud SQL Auth Proxy connector)
# -----------------------------------------------------------------------
# Local Docker Compose: use the plain JDBC URL below (matches docker-compose.yml)
DB_URL=jdbc:postgresql://db:5432/loras

# Cloud Run / production: use the Cloud SQL socket factory URL
# DB_URL=jdbc:postgresql:///loras?cloudSqlInstance=PROJECT:REGION:INSTANCE&socketFactory=com.google.cloud.sql.postgres.SocketFactory

DB_USERNAME=loras
DB_PASSWORD=changeme

# -----------------------------------------------------------------------
# Google Cloud Storage
# -----------------------------------------------------------------------
GCS_BUCKET_NAME=loras-media

# -----------------------------------------------------------------------
# JWT (min 256-bit entropy, Base64-encoded)
# Generate a secure value with: openssl rand -base64 64
# -----------------------------------------------------------------------
JWT_SECRET=
JWT_COOKIE_DOMAIN=localhost

# -----------------------------------------------------------------------
# SMTP (Gmail)
# For local development consider a sink service like Mailtrap or MailHog.
# -----------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# -----------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------
CONTACT_EMAIL=asryantigran@gmail.com

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173
